ally.\n CAUTION: Since the beacon address can never be changed, you must ensure that you either control the beacon, or trust\n the beacon to not upgrade the implementation maliciously.\n IMPORTANT: Do not use the implementation logic to modify the beacon storage slot. Doing so would leave the proxy in\n an inconsistent state where the beacon storage slot does not match the beacon address."},"fullyImplemented":true,"linearizedBaseContracts":[37336,37278],"name":"BeaconProxy","nameLocation":"1125:11:33","scope":37337,"usedErrors":[36968,36978,36981,39328,40462],"usedEvents":[36733]}],"license":"MIT"},"id":33}